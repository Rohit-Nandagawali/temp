<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="@color/cl_black"

    android:orientation="vertical"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_bold"
        android:text="Your Dahboard"
        android:layout_marginTop="25dp"
        android:layout_marginLeft="3dp"
        android:layout_marginBottom="0dp"
        android:textColor="@color/cl_green"
        android:textSize="30sp" />
 <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_bold"
        android:text="Your hub for insights, history, and management."
        android:layout_marginLeft="5dp"
     android:layout_marginTop="0dp"
     android:layout_marginBottom="20dp"
        android:textColor="@color/cl_faint_green"
        android:textSize="10sp" />

    <!-- Card 1 -->
    <LinearLayout
        android:id="@+id/btnManageEV"
        android:layout_height="wrap_content"
        android:layout_width="wrap_content"
        android:layout_margin="8dp"
        android:background="@drawable/edittext_background"

        app:cardCornerRadius="15dp">

        <LinearLayout

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp">

            <!-- Image -->
            <com.google.android.material.imageview.ShapeableImageView

                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center_vertical"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/ImageView.SmallRound"
                android:src="@drawable/evstation" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Title -->
                <TextView

                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"

                    android:text="Manage EV points "
                  android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Subtitle -->
                <TextView

                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:lines="2"
                    android:text="Effortlessly oversee your EV charging stations with ease and efficiency."
                    android:textColor="@android:color/darker_gray"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>


    <!-- Card 3 -->
    <LinearLayout
        android:id="@+id/btnGetAllReview"
        android:layout_height="wrap_content"
        android:layout_width="wrap_content"
        android:layout_margin="8dp"
        android:background="@drawable/edittext_background"

        app:cardCornerRadius="15dp">

        <LinearLayout

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp">

            <!-- Image -->
            <com.google.android.material.imageview.ShapeableImageView

                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center_vertical"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/ImageView.SmallRound"
                android:src="@drawable/history" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Title -->
                <TextView

                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"

                    android:text="Review History"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Subtitle -->
                <TextView

                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:lines="2"
                    android:text="Track and view your past reviews and ratings."
                    android:textColor="@android:color/darker_gray"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>


        <!--            &lt;!&ndash; Your card content here &ndash;&gt;-->

    </LinearLayout>

    <!-- Card 4 -->
    <LinearLayout
        android:id="@+id/btnPaymentHistory"
        android:layout_height="wrap_content"
        android:layout_width="wrap_content"
        android:layout_margin="8dp"
        android:background="@drawable/edittext_background"

        app:cardCornerRadius="15dp">

        <LinearLayout

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp">

            <!-- Image -->
            <com.google.android.material.imageview.ShapeableImageView

                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center_vertical"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/ImageView.SmallRound"
                android:src="@drawable/money" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Title -->
                <TextView

                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"

                    android:text="Payment History"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Subtitle -->
                <TextView

                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:lines="2"
                    android:text="View your past transactions and payment details."
                    android:textColor="@android:color/darker_gray"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>


        <!--            &lt;!&ndash; Your card content here &ndash;&gt;-->

    </LinearLayout>

<!-- Card 5 -->
    <LinearLayout
        android:id="@+id/btnAnalytics"
        android:layout_height="wrap_content"
        android:layout_width="wrap_content"
        android:layout_margin="8dp"
        android:background="@drawable/edittext_background"

        app:cardCornerRadius="15dp">

        <LinearLayout

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp">

            <!-- Image -->
            <com.google.android.material.imageview.ShapeableImageView

                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center_vertical"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/ImageView.SmallRound"
                android:src="@drawable/analytics" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Title -->
                <TextView

                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"

                    android:text="Bussiness Analytics"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Subtitle -->
                <TextView

                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:lines="2"
                    android:text="Track customer service metrics and revenue generation"
                    android:textColor="@android:color/darker_gray"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>


        <!--            &lt;!&ndash; Your card content here &ndash;&gt;-->

    </LinearLayout>

    <!-- Card 2 -->
    <LinearLayout
        android:id="@+id/btnProfile"

        android:layout_height="wrap_content"
        android:layout_width="wrap_content"
        android:layout_margin="8dp"
        android:background="@drawable/edittext_background"

        app:cardCornerRadius="15dp">

        <LinearLayout

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp">

            <!-- Image -->
            <com.google.android.material.imageview.ShapeableImageView

                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center_vertical"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/ImageView.SmallRound"
                android:src="@drawable/profile" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Title -->
                <TextView

                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"

                    android:text="Manage Your Profile "
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Subtitle -->
                <TextView

                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:lines="2"
                    android:text="Manage your personal information and preferences."
                    android:textColor="@android:color/darker_gray"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>


        <!--            &lt;!&ndash; Your card content here &ndash;&gt;-->

    </LinearLayout>




